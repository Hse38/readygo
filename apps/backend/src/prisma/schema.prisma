generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String?
  surname          String?
  occupation       String?
  workLocation     String?
  workLocationLat  Float?
  workLocationLng  Float?
  homeLocation     String?
  homeLocationLat  Float?
  homeLocationLng  Float?
  workDays         String[]
  transportMode    String?
  morningAlarm     Boolean?
  createdAt        DateTime @default(now())

  events          Event[]
  participations  Participant[]
}

model Event {
  id           String   @id @default(cuid())
  userId       String
  title        String
  type         String
  date         DateTime
  location     String?
  locationLat  Float?
  locationLng  Float?
  travelMode   String?
  createdAt    DateTime @default(now())

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  checklistItems ChecklistItem[]
  participants   Participant[]

  @@index([userId])
}

model Participant {
  id          String   @id @default(cuid())
  eventId     String
  userId      String?
  email       String
  name        String?
  status      String   @default("pending")
  inviteToken String   @unique @default(cuid())
  createdAt   DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id])

  @@index([eventId])
  @@index([userId])
}

model ChecklistItem {
  id          String    @id @default(cuid())
  eventId     String
  title       String
  isCompleted Boolean   @default(false)
  scheduledAt DateTime?

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}
