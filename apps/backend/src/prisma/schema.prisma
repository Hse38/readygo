generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EventType {
  flight
  exam
  wedding
  meeting
  doctor
  concert
  travel
  sport
  birthday
  ceremony
  legal
  other
}

enum ItemPriority {
  critical
  important
  optional
}

enum ChecklistItemSource {
  template
  ai
}

enum EventProcessingState {
  created
  processing
  processed
  failed
  archived
}

enum NotificationPriority {
  critical
  important
  optional
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String?
  surname          String?
  occupation       String?
  workLocation     String?
  workLocationLat  Float?
  workLocationLng  Float?
  homeLocation     String?
  homeLocationLat  Float?
  homeLocationLng  Float?
  workDays         String[]
  transportMode    String?
  morningAlarm     Boolean?
  createdAt        DateTime @default(now())

  events          Event[]
  participations  Participant[]
}

model Event {
  id                 String    @id @default(cuid())
  userId             String
  title              String
  type               EventType
  date               DateTime
  location           String?
  locationLat        Float?
  locationLng        Float?
  travelMode         String?
  metadata           Json?
  processingState    EventProcessingState @default(created)
  processingError    String?
  processingStartedAt DateTime?
  processingFinishedAt DateTime?
  retryCount         Int                 @default(0)
  processingHash     String?
  lastProcessedVersion String?
  engineVersion      Int                 @default(1)
  templateVersion    Int                 @default(1)
  timelineVersion    Int                 @default(1)
  notificationVersion Int                @default(1)
  travelVersion      Int                 @default(1)
  processedAt        DateTime?
  intelligenceVersion Int      @default(1)
  createdAt          DateTime  @default(now())

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  checklistItems ChecklistItem[]
  timelineItems  TimelineItem[]
  notificationPlans NotificationPlan[]
  processingLogs EventProcessingLog[]
  participants   Participant[]

  @@index([userId])
}

model Participant {
  id          String   @id @default(cuid())
  eventId     String
  userId      String?
  email       String
  name        String?
  status      String   @default("pending")
  inviteToken String   @unique @default(cuid())
  createdAt   DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id])

  @@index([eventId])
  @@index([userId])
}

model ChecklistItem {
  id          String              @id @default(cuid())
  eventId     String
  title       String
  isCompleted Boolean             @default(false)
  scheduledAt DateTime?
  priority    ItemPriority        @default(important)
  source      ChecklistItemSource @default(template)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model TimelineItem {
  id          String       @id @default(cuid())
  eventId     String
  title       String
  scheduledAt DateTime
  type        String
  priority    ItemPriority @default(important)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model NotificationPlan {
  id          String       @id @default(cuid())
  eventId     String
  title       String
  scheduledAt DateTime
  priority    NotificationPriority @default(important)
  sentAt      DateTime?

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model EventProcessingLog {
  id          String   @id @default(cuid())
  eventId     String
  stage       String
  status      String
  startedAt   DateTime
  finishedAt  DateTime?
  durationMs  Int?
  errorMessage String?
  metadata    Json?

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([stage])
}
